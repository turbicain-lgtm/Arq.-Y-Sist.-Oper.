    {
        "id": "6fa54911c132a724",
        "type": "function",
        "z": "2f7ae58844a9095b",
        "name": "function BTC",
        "func": "// Redondea y mueve el payload.price a payload\nlet price = Math.round(msg.payload.price);\nmsg.payload = price;\n\n// Para incializar los limites de Gauge y Chart\n// Se ejcuta una sola vez al comienzo con un deploy\n// Tomo un 1% mas para maximo y 1% menos para el minimo\nlet initialized = flow.get('btc_initialized') || false;\n\nif (!initialized) {\n    let min = Math.round(price * 0.99);\n    let max = Math.round(price * 1.01);\n\n    // ui_control actualiza tanto el chart (ymin/ymax) como el gauge (min/max)\n    msg.ui_control = { min: min, max: max, ymin: min, ymax: max };\n\n    flow.set('btc_initialized', true);\n\n    // Mustra en LOG\n    node.warn(\"BTC límites seteados: min=\" + min + \" max=\" + max);\n}\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "\nflow.set('btc_initialized', false);",
        "finalize": "",
